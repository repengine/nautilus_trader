[MASTER]
ignore-patterns=^test_.*\.py$,^conftest\.py$
jobs=0
py-version=3.12

[MESSAGES CONTROL]
disable=
    missing-docstring,
    invalid-name,
    too-few-public-methods,
    no-member,
    import-error

[FORMAT]
max-line-length=100

[DESIGN]
max-args=10
max-attributes=20
max-bool-expr=5
max-branches=20
max-locals=25
max-parents=10
max-public-methods=30
max-returns=6
max-statements=80
min-public-methods=0

