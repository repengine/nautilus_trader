# ML Pipeline Environment Configuration
# Copy this file to .env and fill in your values

# Databento API Configuration
DATABENTO_API_KEY=your_databento_api_key_here
DATABENTO_DATASET=EQUS.MINI

# Pipeline Mode Configuration
# Options: daily, backfill, realtime
PIPELINE_MODE=daily

# Schedule for daily mode (cron format)
# Default: 5 PM daily (after market close)
PIPELINE_SCHEDULE=0 17 * * *

# Universe Configuration
# Comma-separated list of symbols
UNIVERSE_SYMBOLS=SPY.XNAS,QQQ.XNAS,IWM.XNAS

# Backfill Configuration (for backfill mode)
BACKFILL_START=2024-01-01
BACKFILL_END=2024-01-31

# Realtime Configuration (for realtime mode)
# Interval in seconds between updates
REALTIME_INTERVAL=300

# Performance Configuration
MAX_WORKERS=4
BATCH_SIZE=1000

# Logging Configuration
LOG_LEVEL=INFO

# Resource Limits (optional overrides)
# MEMORY_LIMIT=16g
# CPU_LIMIT=4