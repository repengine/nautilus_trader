# Nautilus Trader ML deployment environment overrides
# Copy this file to `.env` in the same directory and adjust values as needed.

# External integrations
DATABENTO_API_KEY=replace-me
DATABENTO_DATASET=EQUS.MINI

# Schedule and pipeline behaviour
PIPELINE_MODE=daily
PIPELINE_SCHEDULE=0 17 * * *
UNIVERSE_SYMBOLS=SPY.XNAS
LOG_LEVEL=INFO

# Host port overrides (each maps host_port:container_port in docker-compose.yml)
POSTGRES_HOST_PORT=5433
REDIS_HOST_PORT=6380
ML_ACTOR_HOST_PORT=8000
ML_STRATEGY_HOST_PORT=8001
ML_PIPELINE_HOST_PORT=8081
ML_DASHBOARD_HOST_PORT=8010
ML_BUS_REDIS_STREAM=ml-events
ML_STREAM_PERSIST_ENABLE=1
ML_STREAM_PERSIST_BATCH_SIZE=256
ML_STREAM_PERSIST_BLOCK_MS=1000
ML_STREAM_PERSIST_POLL_INTERVAL_SECONDS=0.5

# Optional: provide a direct host connection string for tooling outside the stack
# ML_DB_CONNECTION=postgresql://postgres:postgres@localhost:5433/nautilus

# Streaming training configuration (event-driven runner)
ML_STREAMING_DATASET_DIR=ml_out/full_tft_95
ML_STREAMING_OUTPUT_DIR=ml_out/tft_streaming_artifacts/full_tft_95
ML_STREAMING_STATE_PATH=ml_out/streaming_training_state.json
ML_STREAMING_MAX_TOTAL_ROWS=120000
ML_STREAMING_MAX_TOTAL_SEQUENCES=90000
ML_STREAMING_MAX_SHARDS=32
ML_STREAMING_MAX_EPOCHS=2
ML_STREAMING_SHARD_ROW_BUDGET=120000
ML_STREAMING_PLAN_INTERVAL_SECONDS=900
ML_STREAMING_PROMOTION_THRESHOLD=0.55
ML_STREAMING_PROMOTION_COMMAND=true
ML_STREAMING_BUS_RETRY_ATTEMPTS=3
ML_STREAMING_BUS_RETRY_DELAY_SECONDS=0.5
ML_STREAMING_ACCELERATOR=auto
ML_STREAMING_DEVICES=1
ML_STREAMING_MAX_PLANS=0
ML_STREAMING_GPU_MONITOR_INTERVAL=30
ML_STREAMING_INCLUDE_MACRO=0
ML_STREAMING_INCLUDE_CALENDAR=0
ML_STREAMING_INCLUDE_EVENTS=0
ML_STREAMING_INCLUDE_EARNINGS=0
ML_STREAMING_INCLUDE_MICRO=0
ML_STREAMING_INCLUDE_L2=0
ML_STREAMING_INCLUDE_MACRO_REVISIONS=0
