# Nautilus Trader ML deployment environment overrides
# Copy this file to `.env` in the same directory and adjust values as needed.

# =============================================================================
# Infrastructure & Database
# =============================================================================
ML_DB_USER=postgres
ML_DB_PASSWORD=postgres
ML_DB_NAME=nautilus
ML_DB_HOST=localhost
ML_DB_PORT=5433
# Optional: explicit PostgreSQL URL for out-of-cluster tooling
ML_DB_CONNECTION=
# Backwards compatibility with legacy configs
DATABASE_URL=
NAUTILUS_DB=

ML_AUTO_START_DB=false
ML_AUTO_MIGRATE=false
ML_ALLOW_DUMMY=false
ML_FILE_STORE_PATH=${HOME}/.nautilus/ml/file_store
ML_MIGRATIONS_SCHEMA=public
ML_MIGRATIONS_FULL=false
ML_DOCKER_TIMEOUT=60
ML_ENV=dev
ML_STRICT_PROTOCOL_VALIDATION=false

# =============================================================================
# Runtime Integration / Observability
# =============================================================================
ML_OBSERVABILITY_ENABLED=false
ML_OBS_SINK=file
ML_OBS_BASE_PATH=./observability
ML_OBS_INTERVAL_SECONDS=60
ML_OBS_ASYNC_ENABLE=false

ML_TRACING_ENABLED=false
ML_TRACING_SERVICE_NAME=nautilus-ml
ML_TRACING_ENDPOINT=
ML_TRACING_SAMPLE_RATE=0.1

ML_LOG_LEVEL=INFO
ML_LOG_FORMAT=json

# =============================================================================
# Message Bus
# =============================================================================
ML_BUS_ENABLE=false
ML_BUS_BACKEND=redis
ML_BUS_REDIS_URL=redis://localhost:6379/0
ML_BUS_REDIS_STREAM=ml-events
ML_BUS_REDIS_MAXLEN=
ML_BUS_FROM_ACTOR=true
ML_BUS_FROM_STORE=false
ML_BUS_TOPIC_PREFIX=events.ml

# =============================================================================
# Actor Configuration
# =============================================================================
MODEL_PATH=/app/models/model.onnx
MODEL_ID=ml_actor_model
MODEL_REGISTRY_DIR=./ml_registry
INSTRUMENT_ID=SPY.EQUS
BAR_TYPE=SPY.EQUS-1-MINUTE-LAST-EXTERNAL
COMPONENT_ID=MLSignalActor-001

ML_PREDICTION_THRESHOLD=0.5
ML_MAX_INFERENCE_LATENCY_MS=5.0
ML_INFERENCE_BATCH_SIZE=1
ML_WARM_UP_PERIOD=50
ML_USE_MANIFEST_FEATURES=true
ML_USE_DUMMY_STORES=false
ML_PUBLISH_SIGNALS=true
ML_LOG_PREDICTIONS=false
ML_ENABLE_HOT_RELOAD=false
ML_MODEL_CHECK_INTERVAL=300
ML_PRESERVE_STATE_ON_RELOAD=true
ML_ENABLE_HEALTH_MONITORING=true
ML_MAX_FEATURE_LATENCY_MS=0.5
ML_LOG_EVENTS=true
ML_LOG_COMMANDS=true
ML_ALLOW_NON_ONNX_IN_DEV=false
ML_ENABLE_ASYNC_PERSISTENCE=true
ML_PERSISTENCE_QUEUE_SIZE=10000
ML_PERSISTENCE_FLUSH_INTERVAL_S=1.0
ML_PERSISTENCE_BATCH_SIZE=100

# =============================================================================
# Strategy Configuration
# =============================================================================
ML_SIGNAL_SOURCE=MLSignalActor-001
STRATEGY_INSTRUMENT_ID=SPY.EQUS
ML_POSITION_SIZE_PCT=0.1
ML_MIN_CONFIDENCE=0.7
ML_MAX_POSITIONS=1
ML_STOP_LOSS_PCT=0.02
ML_TAKE_PROFIT_PCT=0.04
ML_USE_STRATEGY_STORE=true
ML_PERSIST_ALL_SIGNALS=false
ML_EXECUTE_TRADES=false

# =============================================================================
# Feature Store / Pipeline Flags
# =============================================================================
ML_USE_LEGACY_FEATURE_STORE=false
ML_USE_COMPONENT_FEATURE_STORE=true
ML_USE_LEGACY_PIPELINE_ORCHESTRATOR=false
ML_USE_COMPONENT_PIPELINE_ORCHESTRATOR=true
ML_TS_NORMALIZATION_MODE=warn

# =============================================================================
# External Integrations
# =============================================================================
DATABENTO_API_KEY=replace-me
DATABENTO_DATASET=EQUS.MINI

# =============================================================================
# Scheduling / Pipeline behaviour
# =============================================================================
PIPELINE_MODE=daily
PIPELINE_SCHEDULE=0 17 * * *
UNIVERSE_SYMBOLS=SPY.XNAS
LOG_LEVEL=INFO

# =============================================================================
# Host port overrides (host_port:container_port)
# =============================================================================
POSTGRES_HOST_PORT=5433
REDIS_HOST_PORT=6380
ML_ACTOR_HOST_PORT=8000
ML_STRATEGY_HOST_PORT=8001
ML_PIPELINE_HOST_PORT=8081
ML_DASHBOARD_HOST_PORT=8010

# =============================================================================
# Streaming training configuration (event-driven runner)
# =============================================================================
ML_STREAM_PERSIST_ENABLE=1
ML_STREAM_PERSIST_BATCH_SIZE=256
ML_STREAM_PERSIST_BLOCK_MS=1000
ML_STREAM_PERSIST_POLL_INTERVAL_SECONDS=0.5

ML_STREAMING_DATASET_DIR=ml_out/full_tft_95
ML_STREAMING_OUTPUT_DIR=ml_out/tft_streaming_artifacts/full_tft_95
ML_STREAMING_STATE_PATH=ml_out/streaming_training_state.json
ML_STREAMING_MAX_TOTAL_ROWS=150000
ML_STREAMING_MAX_TOTAL_SEQUENCES=112500
ML_STREAMING_MAX_SHARDS=40
ML_STREAMING_MAX_EPOCHS=2
ML_STREAMING_SHARD_ROW_BUDGET=150000
ML_STREAMING_PLAN_INTERVAL_SECONDS=900
ML_STREAMING_PROMOTION_THRESHOLD=0.55
ML_STREAMING_PROMOTION_COMMAND=
ML_STREAMING_BUS_RETRY_ATTEMPTS=3
ML_STREAMING_BUS_RETRY_DELAY_SECONDS=0.5
ML_STREAMING_ACCELERATOR=auto
ML_STREAMING_DEVICES=1
ML_STREAMING_MAX_PLANS=0
ML_STREAMING_GPU_MONITOR_INTERVAL=30
ML_STREAMING_DATASET_SEED=7
ML_STREAMING_WORKER_SEED=7
ML_STREAMING_INCLUDE_MACRO=0
ML_STREAMING_INCLUDE_CALENDAR=0
ML_STREAMING_INCLUDE_EVENTS=0
ML_STREAMING_INCLUDE_EARNINGS=0
ML_STREAMING_INCLUDE_MICRO=0
ML_STREAMING_INCLUDE_L2=0
ML_STREAMING_INCLUDE_MACRO_REVISIONS=0
