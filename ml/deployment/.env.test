# Environment overrides for the ml-test stack (mock data / integration tests)
# Invoke with: docker compose --env-file ml/deployment/.env.test -f ml/deployment/docker-compose.test.yml up -d

# Host port bindings (kept distinct from production stack)
TEST_POSTGRES_HOST_PORT=5534
TEST_REDIS_HOST_PORT=6481
TEST_ACTOR_HOST_PORT=8202
TEST_PROMETHEUS_HOST_PORT=9191

# Optional signal logging overrides for noisy tests
LOG_LEVEL=DEBUG
