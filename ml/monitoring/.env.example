# Grafana Dashboard Integration Environment Configuration
# Copy this file to .env and update the values for your environment

# ================================
# GRAFANA CONFIGURATION
# ================================

# Grafana server URL (without trailing slash)
GRAFANA_URL=http://localhost:3000

# Grafana authentication (use either API token OR username/password)
GRAFANA_API_TOKEN=your-api-token-here
# GRAFANA_USERNAME=admin
# GRAFANA_PASSWORD=nautilus123

# SSL verification for HTTPS connections
GRAFANA_VERIFY_SSL=true

# API request timeout in seconds
GRAFANA_TIMEOUT=30

# ================================
# PROMETHEUS CONFIGURATION
# ================================

# Prometheus server URL (without trailing slash)
PROMETHEUS_URL=http://localhost:9090

# Prometheus query timeout in seconds
PROMETHEUS_TIMEOUT=30

# Enable/disable Prometheus SSL verification
PROMETHEUS_VERIFY_SSL=true

# ================================
# ALERTMANAGER CONFIGURATION
# ================================

# Alertmanager server URL (without trailing slash)
ALERTMANAGER_URL=http://localhost:9093

# Alertmanager timeout in seconds
ALERTMANAGER_TIMEOUT=30

# ================================
# DASHBOARD MANAGEMENT
# ================================

# Default dashboard folder name in Grafana
ML_DASHBOARD_FOLDER=ML Monitoring

# Default dashboard refresh rate
DEFAULT_DASHBOARD_REFRESH=30s

# Default time range for dashboards
DEFAULT_TIME_FROM=now-6h
DEFAULT_TIME_TO=now

# Auto-create ML folder if it doesn't exist
AUTO_CREATE_FOLDER=true

# Backup existing dashboards before overwriting
BACKUP_DASHBOARDS=true

# Dashboard backup directory (relative to monitoring root)
BACKUP_DIR=./backups

# ================================
# LOGGING CONFIGURATION
# ================================

# Log level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# Log format (json, text)
LOG_FORMAT=text

# Log to file (set to empty string to disable file logging)
LOG_FILE=./logs/dashboard_management.log

# Maximum log file size in MB
LOG_MAX_SIZE=10

# Number of log files to keep
LOG_BACKUP_COUNT=5

# ================================
# VALIDATION SETTINGS
# ================================

# Enable strict validation (warnings treated as errors)
STRICT_VALIDATION=false

# Enable detailed validation output
DETAILED_VALIDATION=false

# Maximum allowed dashboard size in KB
MAX_DASHBOARD_SIZE=1024

# Maximum number of panels per dashboard
MAX_PANELS_PER_DASHBOARD=50

# ================================
# PERFORMANCE SETTINGS
# ================================

# Maximum concurrent operations for batch processing
MAX_CONCURRENT_OPERATIONS=5

# Request retry configuration
MAX_RETRIES=3
RETRY_BACKOFF_FACTOR=0.3

# Rate limiting (requests per second, 0 to disable)
RATE_LIMIT=10

# ================================
# SECURITY SETTINGS
# ================================

# Enable/disable SSL certificate verification globally
VERIFY_SSL_CERTIFICATES=true

# Allowed Grafana hosts (comma-separated, empty for any)
ALLOWED_GRAFANA_HOSTS=localhost,127.0.0.1

# API token encryption key (for storing tokens securely)
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
# API_TOKEN_ENCRYPTION_KEY=

# ================================
# MONITORING SETTINGS
# ================================

# Enable dashboard health checks
ENABLE_HEALTH_CHECKS=true

# Health check interval in seconds
HEALTH_CHECK_INTERVAL=300

# Dashboard performance monitoring
MONITOR_DASHBOARD_PERFORMANCE=true

# Performance threshold in seconds (warn if dashboard loads slower)
DASHBOARD_LOAD_THRESHOLD=2.0

# ================================
# NOTIFICATION SETTINGS
# ================================

# Enable notifications for dashboard operations
ENABLE_NOTIFICATIONS=false

# Notification webhook URL (for Slack, Teams, etc.)
# NOTIFICATION_WEBHOOK_URL=

# Notification channels (comma-separated)
# NOTIFICATION_CHANNELS=ml-alerts,ops-alerts

# Email notifications
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USERNAME=
# SMTP_PASSWORD=
# SMTP_FROM_EMAIL=nautilus-monitoring@example.com
# NOTIFICATION_EMAILS=ops@example.com,ml-team@example.com

# ================================
# DEVELOPMENT/TESTING
# ================================

# Enable debug mode (more verbose logging, no actual changes)
DEBUG_MODE=false

# Dry run mode (simulate operations without making changes)
DRY_RUN=false

# Test data directory for validation testing
TEST_DATA_DIR=./test_data

# Mock Grafana API for testing
MOCK_GRAFANA_API=false

# ================================
# DOCKER COMPOSE OVERRIDES
# ================================

# Override Docker Compose service ports
GRAFANA_PORT=3000
PROMETHEUS_PORT=9090
ALERTMANAGER_PORT=9093
PUSHGATEWAY_PORT=9091
NODE_EXPORTER_PORT=9100

# Docker network name
DOCKER_NETWORK=nautilus_monitoring

# Data volume paths (absolute paths or named volumes)
GRAFANA_DATA_PATH=./data/grafana
PROMETHEUS_DATA_PATH=./data/prometheus
ALERTMANAGER_DATA_PATH=./data/alertmanager

# ================================
# ADVANCED CONFIGURATION
# ================================

# Custom dashboard template directory
CUSTOM_TEMPLATE_DIR=./templates

# Dashboard versioning (auto-increment version on update)
AUTO_VERSION_DASHBOARDS=true

# Git integration for dashboard version control
GIT_ENABLED=false
GIT_REPOSITORY=
GIT_BRANCH=main
GIT_COMMIT_MESSAGE_TEMPLATE=Update ML dashboard: {dashboard_title}

# Dashboard diff/comparison settings
ENABLE_DASHBOARD_DIFF=true
DIFF_IGNORE_FIELDS=version,iteration,id

# Export format options
EXPORT_FORMAT=json
EXPORT_PRETTY_PRINT=true
EXPORT_INCLUDE_METADATA=false

# Import validation settings
VALIDATE_BEFORE_IMPORT=true
SKIP_INVALID_DASHBOARDS=false
CONTINUE_ON_ERROR=true